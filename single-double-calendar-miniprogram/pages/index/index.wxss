/* 全局容器 */
.container {
  background: #f0f2f5;
  min-height: 100vh;
  padding: 20rpx 24rpx;
  padding-bottom: 60rpx;
}

/* 标题行（居中） */
.header {
  text-align: center;
  margin-bottom: 16rpx;
}
.title {
  font-size: 44rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #2c3e66, #1e4a6b);
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}

/* 副标题（单独一行，居中） */
.subtitle-row {
  text-align: center;
  margin-bottom: 12rpx;
}
.subtitle {
  font-size: 24rpx;
  color: #475569;
}

/* 按钮组（单独一行，居中，且尺寸缩小） */
.view-switch {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.switch-btn {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  background: #f1f5f9;
  color: #475569;
  border: none;
  line-height: 1.2;
}
.switch-btn.active {
  background: #3b82f6;
  color: white;
}

/* 月份导航（单月视图） */
.month-nav {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
}
.month-display {
  background: white;
  padding: 12rpx 32rpx;
  border-radius: 60rpx;
  border: 1rpx solid #cbd5e1;
  font-size: 32rpx;
  font-weight: 500;
  color: #1e293b;
}

/* 可折叠设置面板 */
.settings-wrapper {
  background: #f8fafc;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #f8fafc;
  border-bottom: 1rpx solid #e2e8f0;
}
.settings-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #334155;
}
.settings-arrow {
  font-size: 28rpx;
  color: #64748b;
}
.settings-content {
  padding: 20rpx 24rpx;
}
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}
.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
}
.picker {
  background: white;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid #cbd5e1;
  font-size: 28rpx;
}
.radio-group {
  display: flex;
  gap: 32rpx;
}
.radio {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
}

/* 单月视图轮播容器 */
.calendar-swiper {
  width: 100%;
  transition: height 0.2s ease;
}

/* 全年视图滚动区域 */
.year-view {
  height: calc(100vh - 400rpx);
  width: 100%;
}
.year-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340rpx, 1fr));
  gap: 24rpx;
  padding-bottom: 40rpx;
}

/* 月份卡片通用样式 */
.month-card {
  background: white;
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid #e9eef3;
  margin-bottom: 20rpx;
}
.month-header {
  background: #f1f5f9;
  padding: 20rpx;
  text-align: center;
  font-weight: 600;
  font-size: 32rpx;
}
.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}
.day-cell {
  min-height: 100rpx;
  padding: 12rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 0.5rpx solid #f1f3f7;
}
.day-number {
  font-size: 28rpx;
  font-weight: 500;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-bottom: 6rpx;
}
.day-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 30rpx;
}

/* 日历标识颜色 */
.day-cell.double .day-tag { background: #dbeafe; color: #075985; }
.day-cell.single .day-tag { background: #ffe4e2; color: #a12a2a; }
.day-cell.holiday .day-tag { background: #fef3c7; color: #b45309; }
.day-cell.workday .day-tag { background: #fed7aa; color: #7b341e; }

/* 底部提示 */
.auto-save-tip {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}